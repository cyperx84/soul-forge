    "arm64"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyperx84/soul-forge.git"
  },
  "homepage": "https://github.com/cyperx84/soul-forge#readme",
  "bugs": "https://github.com/cyperx84/soul-forge/issues",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "hermes",
    "soul.md",
